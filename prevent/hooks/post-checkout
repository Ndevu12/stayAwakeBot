#!/usr/bin/env bash
# StayAwakeBot worm post-checkout hook — scans code pulled in on a fresh clone or when
# switching branches, before you start working in a possibly-infected tree.
# Args (git-provided): $1 prev-HEAD  $2 new-HEAD  $3 1=branch checkout, 0=file checkout
set -uo pipefail
. "$(dirname "$0")/_worm_lib.sh"

prev="${1:-}"; new="${2:-}"; is_branch="${3:-0}"
[ "$is_branch" = "1" ] || exit 0    # ignore file (path) checkouts

files=()
if [ "$prev" = "0000000000000000000000000000000000000000" ]; then
  # Fresh clone: scan every tracked file once.
  while IFS= read -r f; do files+=("$f"); done < <(git ls-files)
else
  while IFS= read -r f; do files+=("$f"); done \
    < <(git diff --name-only --diff-filter=ACM "$prev" "$new" 2>/dev/null)
fi
[ ${#files[@]} -eq 0 ] && exit 0

if ! worm_scan_files "${files[@]}"; then
  echo ""
  echo "⚠️  Worm indicators in checked-out code (StayAwakeBot)."
  echo "    Inspect & clean: stayawake-security-scan --local-only && stayawake-security-remediate --apply"
fi
exit 0
